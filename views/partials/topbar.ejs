<header class="topbar">
    <button class="topbar-btn menu-toggle" id="menuToggle">
        <i class="fas fa-bars"></i>
    </button>
    <h1 class="topbar-title">
        <%= typeof pageTitle !=='undefined' ? pageTitle : 'Dashboard' %>
    </h1>

    <div class="topbar-actions">
        <!-- Theme Toggle -->
        <button class="topbar-btn" onclick="toggleTheme()" title="Toggle Theme">
            <i id="themeIcon" class="fas fa-sun"></i>
        </button>

        <!-- Notifications -->
        <div style="position:relative">
            <button class="topbar-btn" id="notifBtn" title="Notifikasi">
                <i class="fas fa-bell"></i>
                <% if (typeof notifCount !=='undefined' && notifCount> 0) { %>
                    <span class="badge-dot"></span>
                    <% } %>
            </button>

            <div class="notif-dropdown" id="notifDropdown">
                <div class="notif-header">
                    <h6>Notifikasi <span id="notifCount"
                            style="background:var(--primary);color:white;padding:2px 8px;border-radius:20px;font-size:0.7rem;">
                            <%= typeof notifCount !=='undefined' ? notifCount : 0 %>
                        </span></h6>
                    <button class="btn btn-xs btn-secondary" onclick="markAllRead()">Baca Semua</button>
                </div>
                <div class="notif-list">
                    <% if (typeof notifications !=='undefined' && notifications.length> 0) { %>
                        <% notifications.forEach(n=> { %>
                            <div class="notif-item <%= !n.is_read ? 'unread' : '' %>"
                                onclick="handleNotifClick('<%= n.id %>', '<%= n.type %>', '<%= n.reference_id %>', <%= !!(typeof user !== 'undefined' && user.isDirector) %>)">
                                <p>
                                    <% if (n.type==='belum_lapor' ) { %><i class="fas fa-exclamation-circle"
                                            style="color:var(--warning)"></i>
                                        <% } %>
                                            <% if (n.type==='laporan_diapprove' ) { %><i class="fas fa-check-circle"
                                                    style="color:var(--success)"></i>
                                                <% } %>
                                                    <% if (n.type==='laporan_direview' ) { %><i class="fas fa-comment"
                                                            style="color:var(--info)"></i>
                                                        <% } %>
                                                            <%= n.message %>
                                </p>
                                <span>
                                    <%= new Date(n.created_at).toLocaleString('id-ID', { timeZone: 'Asia/Jakarta' ,
                                        day: '2-digit' , month: '2-digit' , year: 'numeric' , hour: '2-digit' ,
                                        minute: '2-digit' }) %>
                                </span>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <div class="notif-empty">
                                        <i class="fas fa-bell-slash"
                                            style="font-size:2rem;opacity:0.3;display:block;margin-bottom:8px;"></i>
                                        Tidak ada notifikasi
                                    </div>
                                    <% } %>
                </div>
            </div>
        </div>

        <!-- User info -->
        <div class="d-flex align-items-center gap-3">
            <div style="font-size:0.8rem;color:var(--text-muted);">
                <i class="fas fa-user-circle me-1"></i>
                <%= user.full_name %>
            </div>
            <a href="/logout" class="btn btn-xs btn-outline-danger" title="Keluar">
                <i class="fas fa-sign-out-alt"></i> Keluar
            </a>
        </div>
    </div>
</header>