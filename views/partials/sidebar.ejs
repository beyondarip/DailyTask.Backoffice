                                                                            <i class="fas fa-exclamation-triangle nav-icon"
                                                                                style="color: #ef4444;"></i>
                                                                            <% } else { %>
                                                                                <i
                                                                                    class="fas fa-certificate nav-icon"></i>
                                                                                <% } %>
                                                                                    Urgent
                                                                                    <% if (typeof urgentCount
                                                                                        !=='undefined' && urgentCount>
                                                                                        0) { %>
                                                                                        <span class="nav-badge"
                                                                                            style="background:#ef4444;">
                                                                                            <%= urgentCount %>
                                                                                        </span>
                                                                                        <% } %>
