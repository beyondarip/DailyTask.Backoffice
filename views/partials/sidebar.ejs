                                                                <div class="nav-item">
                                                                    <a class="nav-link <%= currentPath === 'sda_employees' ? 'active' : '' %>"
                                                                        href="/sda/employees">
                                                                        <i class="fas fa-users nav-icon"></i> Data
                                                                        Karyawan
                                                                    </a>
                                                                </div>
                                                                <div class="nav-item">
                                                                    <a class="nav-link <%= currentPath === 'activity_log' ? 'active' : '' %>"
                                                                        href="/sda/activity_log">
                                                                        <i class="fas fa-history nav-icon"></i> Activity
                                                                        Log
                                                                    </a>
                                                                </div>
                                                                <div class="nav-item">
                                                                    <a class="nav-link <%= currentPath === 'urgent' ? 'active' : '' %>"
                                                                        href="/sda/urgent"
