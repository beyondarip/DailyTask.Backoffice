                <div>
                    <div class="user-info-name">
                        <%= user.full_name %>
                    </div>
                    <span class="role-badge role-<%= role %>">
                        <%= role==='super_duper_admin' ? 'SDA' : role==='super_admin' ? 'SA' : role==='admin_divisi'
                            ? 'Admin' : 'User' %>
                    </span>
                </div>
            </div>
