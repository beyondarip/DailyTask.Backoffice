<% const role=user.role_name; const deptName=(user.department_name || '' ).toLowerCase(); const
    isFinance=['sales','marketing','finance','purchasing'].includes(deptName); const isProduksi=deptName==='produksi' ;
    const currentPath=typeof activePage !=='undefined' ? activePage : '' ; %>
    <nav class="sidebar">
        <a href="<%= user.isDirector ? '/director/dashboard' : (user.role_name === 'super_duper_admin' ? '/sda/dashboard' : (user.role_name === 'super_admin' ? '/sa/dashboard' : (user.role_name === 'admin_divisi' ? '/admin/dashboard' : '/dashboard'))) %>"
