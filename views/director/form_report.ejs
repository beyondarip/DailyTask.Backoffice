<% const isEdit=typeof report !=='undefined' && report; const title=isEdit ? 'Edit Laporan Direksi'
    : 'Buat Laporan Direksi Baru' ; const pageTitle=title; const activePage='director_new_report' ; %>
    <%- include('../partials/layout_head') %>

        <div class="page-header">
            <h1><i class="fas fa-<%= isEdit ? 'edit' : 'plus-circle' %> me-2 text-primary"></i>
                <%= title %>
            </h1>
            <p>Director Mode | Role: <strong>
                    <%= user.role_name.toUpperCase() %>
                </strong></p>
        </div>

        <% if (typeof error !=='undefined' && error) { %>
            <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i>
                <%= error %>
            </div>
            <% } %>

                <div class="row g-4">
                    <div class="col-lg-8">
                        <div class="card shadow-sm border-0" style="border-radius: 16px;">
                            <div class="card-header bg-transparent border-0 py-3 ps-4">
                                <h5 class="mb-0 fw-bold"><i
                                        class="fas fa-file-signature me-2 text-primary"></i>Executive Report Entry</h5>
                            </div>
                            <div class="card-body p-4 pt-0">
                                <form
                                    action="<%= isEdit ? '/director/report/edit/' + report.id : '/director/report/new' %>"
                                    method="POST" enctype="multipart/form-data" id="reportForm">

                                    <div class="row g-3 mb-4">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label class="form-label text-muted small fw-bold">TANGGAL
                                                    LAPORAN</label>
                                                <% const displayDate=isEdit && report.report_date ? new
                                                    Date(report.report_date).toLocaleDateString('id-ID', {
                                                    day: '2-digit' , month: 'long' , year: 'numeric' }) : new
                                                    Date().toLocaleDateString('id-ID', { day: '2-digit' , month: 'long'
                                                    , year: 'numeric' }); %>
                                                    <div class="form-control bg-light border-0 fw-bold py-3 px-3"
                                                        style="color: var(--primary); border-radius:12px;">
                                                        <i class="fas fa-calendar-alt me-2"></i>
                                                        <%= displayDate %>
                                                    </div>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label class="form-label text-muted small fw-bold">WAKTU (AUTO)</label>
                                                <% const now=new Date(); const
                                                    currentTime=now.toLocaleTimeString('en-GB', { hour: '2-digit' ,
                                                    minute: '2-digit' , hour12: false }); const timeValue=isEdit ?
                                                    report.report_time.substring(0,5) : currentTime; %>
                                                    <input type="time" class="form-control bg-light border-0 py-3 px-3"
                                                        style="border-radius:12px;" name="report_time"
                                                        value="<%= timeValue %>" readonly>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-group mb-4">
                                        <label class="form-label text-muted small fw-bold">LAPORAN KERJA HARIAN </label>
                                        <textarea class="form-control border-0 bg-light p-3" style="border-radius:12px;"
                                            name="task_description" rows="5" required
                                            placeholder="Apa keputusan atau aktifitas utama hari ini?"><%= isEdit ? report.task_description : '' %></textarea>
                                    </div>

                                    <div class="form-group mb-4">
                                        <label class="form-label text-muted small fw-bold">MASALAH / KENDALA
                                            (OPSIONAL)</label>
                                        <textarea class="form-control border-0 bg-light p-3" style="border-radius:12px;"
                                            name="issue" rows="3"
                                            placeholder="Hambatan atau masalah yang dihadapi..."><%= isEdit ? report.issue : '' %></textarea>
                                    </div>

                                    <div class="form-group mb-4">
                                        <label class="form-label text-muted small fw-bold">SOLUSI / TINDAKAN
                                            (OPSIONAL)</label>
                                        <textarea class="form-control border-0 bg-light p-3" style="border-radius:12px;"
                                            name="solution" rows="3"
                                            placeholder="Solusi atau tindakan yang diambil..."><%= isEdit ? report.solution : '' %></textarea>
                                    </div>



                                    <div class="form-group mb-4">
                                        <label class="form-label text-muted small fw-bold"><i
                                                class="fas fa-paperclip me-2"></i>LAMPIRAN DOKUMEN (OPSIONAL)</label>

                                        <% if (isEdit && report.attachment_path) { %>
                                            <div class="mb-3">
                                                <small class="text-muted d-block mb-2">File Terpilih Saat Ini:</small>
                                                <div class="position-relative border rounded overflow-hidden d-inline-block"
                                                    style="height: 100px; width: 100px; background: #f8fafc;">
                                                    <% if (report.attachment_path.toLowerCase().endsWith('.pdf')) { %>
                                                        <a href="/director/attachment/<%= report.attachment_path.split('/').pop() %>"
                                                            target="_blank"
                                                            class="d-flex align-items-center justify-content-center h-100 text-danger text-decoration-none">
                                                            <i class="fas fa-file-pdf fa-3x"></i>
                                                        </a>
                                                        <% } else { %>
                                                            <a href="/director/attachment/<%= report.attachment_path.split('/').pop() %>"
                                                                target="_blank">
                                                                <img src="/director/attachment/<%= report.attachment_path.split('/').pop() %>"
                                                                    class="w-100 h-100" style="object-fit: cover;">
                                                            </a>
                                                            <% } %>
                                                </div>
                                                <div class="alert alert-info py-2 mt-2" style="font-size: 0.75rem;">
                                                    <i class="fas fa-info-circle me-1"></i>
                                                    Mengupload file baru akan menggantikan lampiran sebelumnya.
                                                </div>
                                            </div>
                                            <% } %>

                                                <input type="file" class="form-control border-0 bg-light p-3"
                                                    style="border-radius:12px;" name="attachments"
                                                    accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" multiple>
                                                <small class="text-muted mt-2 d-block px-1">Unggah dokumen pendukung
                                                    jika diperlukan. Bisa pilih beberapa file sekaligus
                                                    (PDF/JPG/PNG/DOC).</small>
                                    </div>

                                    <div class="card bg-primary-subtle border-0 mb-4"
                                        style="background: rgba(99, 102, 241, 0.05); border-radius: 12px;">
                                        <div class="card-body">
                                            <label class="form-label text-muted small fw-bold mb-3">KONFIRMASI
                                                STATUS</label>
                                            <div class="d-flex gap-4">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="status_action"
                                                        id="statusDraft" value="draft" checked>
                                                    <label class="form-check-label" for="statusDraft">Draft
                                                        (Private)</label>
                                                </div>
                                                <div class="form-check">
                                                    <input class="form-check-input" type="radio" name="status_action"
                                                        id="statusSubmit" value="submit">
                                                    <label class="form-check-label" for="statusSubmit">Finalize
                                                        (Confirm)</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="d-flex gap-2">
                                        <button type="submit" class="btn btn-primary px-5 py-3 shadow-sm"
                                            style="border-radius:12px;">
                                            <i class="fas fa-save me-2"></i> SIMPAN LAPORAN
                                        </button>
                                        <a href="/director/dashboard" class="btn btn-light px-4 py-3"
                                            style="border-radius:12px;">BATAL</a>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm mb-4" style="border-radius: 16px;">
                            <div class="card-body p-4">
                                <h6 class="fw-bold mb-3"><i class="fas fa-shield-alt me-2 text-primary"></i>Director
                                    Confidentiality</h6>
                                <p class="small text-muted mb-0">Laporan dalam mode ini bersifat rahasia dan hanya dapat
                                    diakses oleh Level Direksi. Data disimpan di lingkungan database yang terpisah.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <%- include('../partials/layout_foot') %>