<% const title='Executive Positions' ; const pageTitle='Kelola Jabatan Eksekutif' ; const
    activePage='director_positions' ; %>
    <%- include('../partials/layout_head') %>

        <div class="page-header d-flex align-items-center justify-content-between">
            <div>
                <h1><i class="fas fa-briefcase me-2"></i>Executive Positions</h1>
                <p>Total: <%= positions.length %> positions available</p>
            </div>
            <button class="btn btn-primary" onclick="openModal()">
                <i class="fas fa-plus"></i> Add Position
            </button>
        </div>

        <% if (typeof msg !=='undefined' && msg) { %>
            <div class="alert alert-success" data-auto-dismiss>
                <i class="fas fa-check-circle"></i>
                <%= msg==='added' ? 'Position added successfully!' : msg==='updated' ? 'Position updated successfully!'
                    : 'Operation successful!' %>
            </div>
            <% } %>
                <% if (typeof err !=='undefined' && err) { %>
                    <div class="alert alert-danger" data-auto-dismiss>
                        <i class="fas fa-exclamation-circle"></i>
                        <%= err %>
                    </div>
                    <% } %>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="card">
                                    <div class="card-body-custom p-0">
                                        <div class="table-wrapper">
                                            <table class="tbl">
                                                <thead>
                                                    <tr>
                                                        <th>#</th>
                                                        <th>Position Name</th>
                                                        <th style="width: 100px;">Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% if (positions.length===0) { %>
                                                        <tr>
                                                            <td colspan="3"
                                                                style="text-align:center;padding:40px;color:var(--text-muted);">
                                                                No positions found.
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                                            <% positions.forEach((p, index)=> { %>
                                                                <tr>
                                                                    <td class="text-muted small fw-bold">#<%= index+1 %>
                                                                    </td>
                                                                    <td><strong>
                                                                            <%= p.position_name %>
                                                                        </strong></td>
                                                                    <td>
                                                                        <button class="btn btn-xs btn-primary"
                                                                            onclick='openModal(<%- JSON.stringify(p) %>)'>
                                                                            <i class="fas fa-edit"></i>
                                                                        </button>
                                                                        <button class="btn btn-xs btn-danger ms-1"
                                                                            onclick="deletePosition(<%= p.id %>, '<%= p.position_name %>')">
                                                                            <i class="fas fa-trash"></i>
                                                                        </button>
                                                                    </td>
                                                                </tr>
                                                                <% }) %>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Modal -->
                        <div class="modal fade" id="posModal" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="modalTitle">Add Position</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form id="posForm" method="POST" action="/director/positions/add">
                                        <div class="modal-body">
                                            <div class="col-12">
                                                <label class="form-label">Position Name *</label>
                                                <input type="text" class="form-control" name="position_name" id="pName"
                                                    required placeholder="e.g. Director, CEO">
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary"
                                                data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-primary">Save Changes</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <script>
                            const modal = new bootstrap.Modal(document.getElementById('posModal'));

                            function openModal(data) {
                                if (data) {
                                    document.getElementById('modalTitle').textContent = 'Edit Position';
                                    document.getElementById('pName').value = data.position_name;
                                    document.getElementById('posForm').action = '/director/positions/edit/' + data.id;
                                } else {
                                    document.getElementById('modalTitle').textContent = 'Add Position';
                                    document.getElementById('posForm').reset();
                                    document.getElementById('posForm').action = '/director/positions/add';
                                }
                                modal.show();
                            }

                            async function deletePosition(id, name) {
                                const result = await Swal.fire({
                                    icon: 'warning',
                                    title: 'Delete Position?',
                                    text: `Are you sure you want to delete "${name}"? Users with this position will be shown as —.`,
                                    showCancelButton: true,
                                    confirmButtonColor: '#ef4444',
                                    confirmButtonText: 'Yes, Delete!',
                                    cancelButtonText: 'Cancel'
                                });
                                if (result.isConfirmed) {
                                    const form = document.createElement('form');
                                    form.method = 'POST';
                                    form.action = '/director/positions/delete/' + id;
                                    document.body.appendChild(form);
                                    form.submit();
                                }
                            }
                        </script>

                        <%- include('../partials/layout_foot') %>