<% const title='Executive Management' ; const pageTitle='Kelola User Eksekutif' ; const activePage='director_users' ; %>
    <%- include('../partials/layout_head') %>

        <div class="page-header d-flex align-items-center justify-content-between">
            <div>
                <h1><i class="fas fa-user-shield me-2"></i>Manage Executives</h1>
                <p>Total: <%= users.length %> executives</p>
            </div>
            <button class="btn btn-primary" onclick="openModal()">
                <i class="fas fa-user-plus"></i> Add Executive
            </button>
        </div>

        <% if (typeof msg !=='undefined' && msg) { %>
            <div class="alert alert-success" data-auto-dismiss>
                <i class="fas fa-check-circle"></i>
                <%= msg==='added' ? 'Executive added successfully!' : msg==='updated'
                    ? 'Executive updated successfully!' : 'Operation successful!' %>
            </div>
            <% } %>
                <% if (typeof err !=='undefined' && err) { %>
                    <div class="alert alert-danger" data-auto-dismiss>
                        <i class="fas fa-exclamation-circle"></i>
                        <%= err %>
                    </div>
                    <% } %>

                        <div class="card mb-3">
                            <div class="card-body-custom p-3">
                                <form method="GET" class="row g-2 align-items-center">
                                    <div class="col-auto">
                                        <label class="fw-bold small text-muted">SEARCH:</label>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="input-group input-group-sm">
                                            <input type="text" class="form-control" name="search"
                                                placeholder="Search by name or email..."
                                                value="<%= typeof filters !== 'undefined' ? filters.search : '' %>"
                                                oninput="clearTimeout(this.delay); this.delay = setTimeout(() => this.form.submit(), 500)">
                                            <button class="btn btn-primary" type="submit">
                                                <i class="fas fa-search"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <% if (typeof filters !=='undefined' && filters.search) { %>
                                        <div class="col-auto">
                                            <a href="/director/users"
                                                class="btn btn-sm btn-outline-secondary rounded-pill">
                                                <i class="fas fa-times me-1"></i>Reset
                                            </a>
                                        </div>
                                        <% } %>
                                </form>
                            </div>
                        </div>

                        <div class="card">
                            <div class="card-body-custom p-0">
                                <div class="table-wrapper">
                                    <table class="tbl">
                                        <thead>
                                            <tr>
                                                <th>#</th>
                                                <th>Name</th>
                                                <th>Email</th>
                                                <th>Company</th>
                                                <th>Role</th>
                                                <th>Position</th>
                                                <th>Status</th>
                                                <th>Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% if (users.length===0) { %>
                                                <tr>
                                                    <td colspan="8"
                                                        style="text-align:center;padding:40px;color:var(--text-muted);">
                                                        No executive records found.
                                                    </td>
                                                </tr>
                                                <% } %>
                                                    <% users.forEach((u, index)=> { %>
                                                        <tr>
                                                            <td class="text-muted small fw-bold">#<%= index+1 %>
                                                            </td>
                                                            <td>
                                                                <div style="display:flex;align-items:center;gap:10px;">
                                                                    <div
                                                                        style="width:32px;height:32px;background:var(--primary);border-radius:8px;display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:0.85rem;">
                                                                        <%= u.full_name.charAt(0) %>
                                                                    </div>
                                                                    <div><strong>
                                                                            <%= u.full_name %>
                                                                        </strong></div>
                                                                </div>
                                                            </td>
                                                            <td style="color:var(--text-muted);">
                                                                <%= u.email %>
                                                            </td>
                                                            <td>
                                                                <span class="badge bg-light text-dark border px-2 py-1">
                                                                    <%= u.company_name || 'Global' %>
                                                                </span>
                                                            </td>
                                                            <td><span class="role-badge role-<%= u.role_name %>">
                                                                    <%= u.role_name.toUpperCase() %>
                                                                </span></td>
                                                            <td>
                                                                <%= u.position_name || '—' %>
                                                            </td>
                                                            <td>
                                                                <span
                                                                    class="badge-status <%= u.is_active ? 'badge-approved' : 'badge-draft' %>">
                                                                    <%= u.is_active ? 'Active' : 'Inactive' %>
                                                                </span>
                                                            </td>
                                                            <td>
                                                                <button class="btn btn-xs btn-primary"
                                                                    onclick='openModal(<%- JSON.stringify(u) %>)'>
                                                                    <i class="fas fa-edit"></i>
                                                                </button>
                                                                <button class="btn btn-xs btn-danger ms-1"
                                                                    onclick="deleteUser(<%= u.id %>, '<%= u.full_name %>')">
                                                                    <i class="fas fa-trash"></i>
                                                                </button>
                                                            </td>
                                                        </tr>
                                                        <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Modal -->
                        <div class="modal fade" id="userModal" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="modalTitle">Add Executive</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <form id="userForm" method="POST" action="/director/users/add">
                                        <input type="hidden" name="id" id="userId">
                                        <div class="modal-body">
                                            <div class="row g-3">
                                                <div class="col-12">
                                                    <label class="form-label">Full Name *</label>
                                                    <input type="text" class="form-control" name="full_name"
                                                        id="uFullName" required>
                                                </div>
                                                <div class="col-12">
                                                    <label class="form-label">Email *</label>
                                                    <input type="email" class="form-control" name="email" id="uEmail"
                                                        required>
                                                </div>
                                                <div class="col-12">
                                                    <label class="form-label">Password <span
                                                            id="pwRequired">*</span></label>
                                                    <input type="password" class="form-control" name="password"
                                                        id="uPassword">
                                                    <small id="pwHint"
                                                        style="color:var(--text-muted);display:none;">Leave blank to
                                                        keep current password</small>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">Role *</label>
                                                    <select class="form-select" name="role_id" id="uRole" required>
                                                        <% roles.forEach(r=> { %>
                                                            <option value="<%= r.id %>">
                                                                <%= r.role_name.toUpperCase() %>
                                                            </option>
                                                            <% }) %>
                                                    </select>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label">Status</label>
                                                    <select class="form-select" name="is_active" id="uStatus">
                                                        <option value="true">Active</option>
                                                        <option value="false">Inactive</option>
                                                    </select>
                                                </div>
                                                <div class="col-12">
                                                    <label class="form-label">Company</label>
                                                    <select class="form-select" name="company_id" id="uCompany">
                                                        <option value="">-- Global / No Company --</option>
                                                        <% companies.forEach(c=> { %>
                                                            <option value="<%= c.id %>">
                                                                <%= c.company_name %>
                                                            </option>
                                                            <% }) %>
                                                    </select>
                                                </div>
                                                <div class="col-12">
                                                    <label class="form-label">Position *</label>
                                                    <select class="form-select" name="position_id" id="uPosition"
                                                        required>
                                                        <option value="">-- Select Position --</option>
                                                        <% positions.forEach(p=> { %>
                                                            <option value="<%= p.id %>">
                                                                <%= p.position_name %>
                                                            </option>
                                                            <% }) %>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-secondary"
                                                data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-primary">Save Changes</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <script>
                            const modal = new bootstrap.Modal(document.getElementById('userModal'));

                            function openModal(data) {
                                if (data) {
                                    document.getElementById('modalTitle').textContent = 'Edit Executive';
                                    document.getElementById('userId').value = data.id;
                                    document.getElementById('uFullName').value = data.full_name;
                                    document.getElementById('uEmail').value = data.email;
                                    document.getElementById('uPassword').required = false;
                                    document.getElementById('pwRequired').style.display = 'none';
                                    document.getElementById('pwHint').style.display = 'block';
                                    document.getElementById('uRole').value = data.role_id;
                                    document.getElementById('uPosition').value = data.position_id || '';
                                    document.getElementById('uCompany').value = data.company_id || '';
                                    document.getElementById('uStatus').value = data.is_active ? 'true' : 'false';
                                    document.getElementById('userForm').action = '/director/users/edit/' + data.id;
                                } else {
                                    document.getElementById('modalTitle').textContent = 'Add Executive';
                                    document.getElementById('userForm').reset();
                                    document.getElementById('uPassword').required = true;
                                    document.getElementById('pwRequired').style.display = '';
                                    document.getElementById('pwHint').style.display = 'none';
                                    document.getElementById('userForm').action = '/director/users/add';
                                }
                                modal.show();
                            }

                            async function deleteUser(id, name) {
                                const result = await Swal.fire({
                                    icon: 'warning',
                                    title: 'Delete Executive?',
                                    text: `Are you sure you want to delete executive "${name}"? This action cannot be undone.`,
                                    showCancelButton: true,
                                    confirmButtonColor: '#ef4444',
                                    confirmButtonText: 'Yes, Delete!',
                                    cancelButtonText: 'Cancel'
                                });
                                if (result.isConfirmed) {
                                    const form = document.createElement('form');
                                    form.method = 'POST';
                                    form.action = '/director/users/delete/' + id;
                                    document.body.appendChild(form);
                                    form.submit();
                                }
                            }
                        </script>

                        <%- include('../partials/layout_foot') %>