<% const title='Setup Multi-Factor Authentication' ; const pageTitle='Setup MFA' ; const activePage='security' ; %>
    <%- include('partials/layout_head') %>

        <div class="row">
            <div class="col-md-6 mx-auto">
                <div class="card shadow-sm border-0 mt-4" style="border-radius: 20px;">
                    <div class="card-body p-5 text-center">
                        <i class="fas fa-qrcode text-primary mb-4" style="font-size: 3rem;"></i>
                        <h3 class="fw-bold mb-3">Aktifkan Dua Faktor</h3>
                        <p class="text-muted mb-4">Pindai kode QR di bawah ini menggunakan aplikasi authenticator Anda
                            (Google Authenticator, Microsoft Authenticator, atau Authy).</p>

                        <% if (typeof query !=='undefined' && query.err==='invalid_token' ) { %>
                            <div class="alert alert-danger py-2 small mb-4">
                                <i class="fas fa-times-circle me-1"></i> Kode yang dimasukkan salah. Silakan coba lagi.
                            </div>
                            <% } %>

                                <div class="qr-container mb-4 d-inline-block p-3 bg-white border rounded-4">
                                    <img src="<%= qrCodeUrl %>" alt="MFA QR Code" class="img-fluid"
                                        style="width: 200px; height: 200px;">
                                </div>

                                <div class="text-start mb-4">
                                    <p class="small text-muted mb-2">Tidak bisa memindai? Masukkan kode rahasia ini
                                        secara manual:</p>
                                    <div class="bg-light p-2 rounded text-center fw-bold font-monospace"
                                        style="letter-spacing: 2px;">
                                        <%= secret %>
                                    </div>
                                </div>

                                <hr class="my-4">

                                <form action="/security/mfa/enable" method="POST">
                                    <div class="mb-4 text-start">
                                        <label class="form-label fw-bold small">Masukkan Kode 6-Digit</label>
                                        <input type="text" name="token"
                                            class="form-control form-control-lg text-center fw-bold"
                                            placeholder="000 000" maxlength="6" autofocus required>
                                    </div>

                                    <button type="submit" class="btn btn-primary w-100 py-3 fw-bold"
                                        style="border-radius: 12px;">
                                        Verifikasi dan Aktifkan
                                    </button>
                                    <a href="/security"
                                        class="btn btn-link w-100 mt-2 text-muted text-decoration-none small">Batalkan
                                        Setup</a>
                                </form>
                    </div>
                </div>
            </div>
        </div>

        <style>
            .qr-container {
                box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
            }

            .form-control:focus {
                border-color: #6366f1;
                box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
            }
        </style>

        <%- include('partials/layout_foot') %>