<% const title='Detail Laporan' ; const pageTitle='Detail Laporan Staff' ; const activePage='dashboard' ; const
    isFinance=financeItems && financeItems.length> 0;
    %>
    <%- include('../partials/layout_head') %>

        <div class="page-header d-flex align-items-center mb-4">
            <a href="/sa/dashboard" class="btn btn-secondary me-3"><i class="fas fa-arrow-left"></i> Kembali</a>
            <div>
                <h1>Detail Laporan Staff</h1>
                <p class="mb-0 text-muted">ID: #<%= report.id %> | <%= report.full_name %> (<%= report.position %>)</p>
            </div>
        </div>

        <div class="row g-4 justify-content-center">
            <div class="col-lg-10">
                <div class="card mb-4 shadow-sm">
                    <div class="card-body-custom">
                        <div class="d-flex justify-content-between mb-4">
                            <div>
                                <h4 class="mb-1">
                                    <%= report.full_name %>
                                </h4>
                                <div class="text-muted">
                                    <%= report.email %>
                                </div>
                                <span class="badge bg-secondary mt-2">
                                    <%= report.department_name %>
                                </span>
                                <span class="badge bg-light text-dark border mt-2 ms-1">
                                    <%= report.company_name %>
                                </span>
                            </div>
                            <div class="text-end">
                                <div class="text-muted small">Tanggal Laporan</div>
                                <h5 class="fw-bold">
                                    <%= new Date(report.report_date).toLocaleDateString('id-ID', {weekday:'long',
                                        day:'numeric', month:'long', year:'numeric'}) %>
                                </h5>
                                <div class="mt-2"><span class="badge-status badge-<%= report.status %>">
                                        <%= report.status.toUpperCase() %>
                                    </span></div>
                            </div>
                        </div>

                        <hr class="my-4" style="border-top:1px solid var(--border-color);">

                        <div class="mb-4">
                            <label class="form-label text-muted small text-uppercase fw-bold">Deskripsi Tugas</label>
                            <div class="p-3 bg-light rounded border text-body" style="white-space:pre-wrap;">
                                <%= report.task_description %>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label text-muted small text-uppercase fw-bold">Kendala /
                                    Masalah</label>
                                <div class="p-3 bg-danger bg-opacity-10 text-danger rounded border"
                                    style="min-height:80px;">
                                    <%= report.issue || '-' %>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small text-uppercase fw-bold">Solusi /
                                    Tindakan</label>
                                <div class="p-3 bg-success bg-opacity-10 text-success rounded border"
                                    style="min-height:80px;">
                                    <%= report.solution || '-' %>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-muted small text-uppercase fw-bold">Hasil Akhir</label>
                            <div class="p-3 bg-light rounded border text-body">
                                <%= report.result || '-' %>
                            </div>
                        </div>

                        <% const isProduksi=(report.department_name || '' ).toLowerCase()==='produksi' ; %>
                            <% if (isFinance || isProduksi) { %>
                                <div class="mb-4">
                                    <label class="form-label text-muted small text-uppercase fw-bold">
                                        <%= isProduksi ? 'Detail Produksi' : 'Detail Keuangan' %>
                                    </label>
                                    <div class="table-responsive border rounded">
                                        <table class="table table-sm table-borderless mb-0 align-middle">
                                            <thead class="bg-light">
                                                <tr>
                                                    <th class="ps-3">
                                                        <%= isProduksi ? 'Keterangan' : 'Item' %>
                                                    </th>
                                                    <th class="text-end">Qty</th>
                                                    <% if (!isProduksi) { %>
                                                        <th class="text-end">Harga Satuan</th>
                                                        <th class="text-end pe-3">Total</th>
                                                        <% } %>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% financeItems.forEach(item=> { %>
                                                    <tr>
                                                        <td class="ps-3">
                                                            <%= item.item_name %>
                                                        </td>
                                                        <td class="text-end">
                                                            <%= item.qty %>
                                                        </td>
                                                        <% if (!isProduksi) { %>
                                                            <td class="text-end">Rp <%=
                                                                    parseFloat(item.unit_price).toLocaleString('id-ID')
                                                                    %>
                                                            </td>
                                                            <td class="text-end fw-bold pe-3">Rp <%=
                                                                    parseFloat(item.total_price).toLocaleString('id-ID')
                                                                    %>
                                                            </td>
                                                            <% } %>
                                                    </tr>
                                                    <% }) %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <% } %>

                                    <% if (typeof attachments !=='undefined' && attachments.length> 0) { %>
                                        <div class="mb-4">
                                            <label class="form-label text-muted small text-uppercase fw-bold">Lampiran (
                                                <%= attachments.length %> File)
                                            </label>
                                            <div class="row g-2 mt-1">
                                                <% attachments.forEach(att=> { %>
                                                    <% if (att.attachment_path) { %>
                                                        <div class="col-6 col-md-4">
                                                            <a href="/attachment/view/<%= att.attachment_path.split('/').pop() %>"
                                                                class="d-block">
                                                                <% if
                                                                    (att.attachment_path.toLowerCase().endsWith('.pdf'))
                                                                    { %>
                                                                    <div
                                                                        class="btn btn-outline-danger btn-sm w-100 py-3 text-center">
                                                                        <i class="fas fa-file-pdf d-block mb-1"></i>
                                                                        Buka
                                                                        PDF
                                                                    </div>
                                                                    <% } else { %>
                                                                        <img src="<%= att.attachment_path %>"
                                                                            class="img-fluid rounded border shadow-sm"
                                                                            style="height:100px; width:100%; object-fit:cover;">
                                                                        <% } %>
                                                            </a>
                                                        </div>
                                                        <% } %>
                                                            <% }) %>
                                            </div>
                                        </div>
                                        <% } else if (report.attachment_path) { %>
                                            <div class="mb-4">
                                                <label
                                                    class="form-label text-muted small text-uppercase fw-bold">Lampiran</label>
                                                <div class="mt-2 text-center">
                                                    <a href="/attachment/view/<%= report.attachment_path.split('/').pop() %>"
                                                        class="d-block">
                                                        <% if (report.attachment_path.toLowerCase().endsWith('.pdf')) {
                                                            %>
                                                            <div class="btn btn-outline-danger btn-sm px-4">
                                                                <i class="fas fa-file-pdf me-1"></i> Buka PDF
                                                            </div>
                                                            <% } else { %>
                                                                <img src="<%= report.attachment_path %>"
                                                                    class="img-fluid rounded border shadow-sm"
                                                                    style="max-height:300px;">
                                                                <% } %>
                                                    </a>
                                                </div>
                                            </div>
                                            <% } %>

                                                <% if (report.manager_note) { %>
                                                    <div class="alert alert-warning border mt-4"
                                                        style="word-break: break-word; overflow-wrap: anywhere;">
                                                        <strong><i class="fas fa-comment-dots me-2"></i>Catatan Manager
                                                            Divisi:</strong>
                                                        <div class="mt-2 text-body">
                                                            <%= report.manager_note %>
                                                        </div>
                                                    </div>
                                                    <% } %>
                    </div>
                </div>
            </div>
        </div>

        <%- include('../partials/layout_foot') %>