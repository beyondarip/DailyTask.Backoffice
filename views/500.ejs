<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>500 — Server Error — Daily Report</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap"
        rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #0f0c29;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            text-align: center;
            padding: 20px;
        }

        h1 {
            font-size: 6rem;
            font-weight: 800;
            background: linear-gradient(135deg, #ef4444, #f59e0b);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0;
            line-height: 1;
        }

        h2 {
            font-size: 1.4rem;
            font-weight: 700;
            margin: 16px 0 8px;
        }

        p {
            color: #94a3b8;
            margin-bottom: 28px;
        }

        a {
            display: inline-block;
            padding: 12px 28px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
        }
    </style>
</head>

<body>
    <div>
        <h1>500</h1>
        <h2>Terjadi Kesalahan Server</h2>
        <p>
            <%= typeof error !=='undefined' ? error : 'Server mengalami masalah. Silakan coba lagi.' %>
        </p>
        <a href="/dashboard">← Kembali ke Dashboard</a>
    </div>
</body>

</html>