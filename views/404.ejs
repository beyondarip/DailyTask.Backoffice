<% const title='404 — Halaman Tidak Ditemukan' ; %>
    <!DOCTYPE html>
    <html lang="id">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>404 — Daily Report</title>
        <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;800&display=swap"
            rel="stylesheet">
        <style>
            body {
                font-family: 'Plus Jakarta Sans', sans-serif;
                background: #0f0c29;
                color: white;
                display: flex;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
                text-align: center;
                padding: 20px;
            }

            h1 {
                font-size: 6rem;
                font-weight: 800;
                background: linear-gradient(135deg, #6366f1, #a855f7);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                margin: 0;
                line-height: 1;
            }

            h2 {
                font-size: 1.4rem;
                font-weight: 700;
                margin: 16px 0 8px;
            }

            p {
                color: #94a3b8;
                margin-bottom: 28px;
            }

            a {
                display: inline-block;
                padding: 12px 28px;
                background: linear-gradient(135deg, #6366f1, #8b5cf6);
                color: white;
                text-decoration: none;
                border-radius: 12px;
                font-weight: 600;
            }

            a:hover {
                opacity: 0.9;
            }
        </style>
    </head>

    <body>
        <div>
            <h1>404</h1>
            <h2>Halaman Tidak Ditemukan</h2>
            <p>Halaman yang kamu cari tidak ada atau sudah dipindahkan.</p>
            <a href="<%= typeof user !== 'undefined' && user ? '/dashboard' : '/login' %>">← Kembali ke Dashboard</a>
        </div>
    </body>

    </html>