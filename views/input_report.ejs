<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daily Report - <%= user.company %>
    </title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&display=swap');

        <% // LOGIKA WARNA SINKRON
        var brandColor='#007AFF';
        var companyName=(user && user.company) ? user.company : "";
        var compUpper=companyName.toUpperCase();

        if (compUpper.includes('WONG HANG')) {
            brandColor='#FF0000';
        }

        else if (compUpper.includes('AKARSA GARMENT')) {
            brandColor='#A50000';
        }

        else if (compUpper.includes('AKSA DIGITEX') || compUpper.includes('AKSADIGITEX')) {
            brandColor='#FFC107';
        }

        else if (compUpper.includes('BITREN')) {
            brandColor='#28A745';
        }

        else if (compUpper.includes('ALAS KAKI')) {
            brandColor='#0056B3';
        }

        else if (compUpper.includes('ALFA DINAMIS')) {
            brandColor='#17A2B8';
        }

        else if (compUpper.includes('DELTA SINERGI')) {
            brandColor='#343A40';
        }

        %> :root {
            --main: <%=brandColor %>;
        }

        body {
            background: #f8f9fa;
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #2d3436;
            min-height: 100vh;
            margin: 0;
            caret-color: transparent;
        }

        .main-container {
            max-width: 800px;
            margin: 50px auto;
            animation: fadeInPage 0.5s ease-out forwards;
            opacity: 0;
        }

        @keyframes fadeInPage {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-out {
            animation: fadeOutPage 0.4s ease-in forwards !important;
        }

        @keyframes fadeOutPage {
            from {
                opacity: 1;
                transform: translateY(0);
            }

            to {
                opacity: 0;
                transform: translateY(-10px);
            }
        }



        .bg-rejected {
            background: #fff1f0;
            color: #cf1322;
        }

        /* Custom Premium Dropdown */
        .dropdown-menu {
            border-radius: 20px !important;
            padding: 12px !important;
            min-width: 250px !important;
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.15) !important;
            border: 1px solid rgba(0, 0, 0, 0.05) !important;
            margin-top: 10px !important;
            z-index: 10000 !important;
            animation: dropdownScale 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        @keyframes dropdownScale {
            from {
                opacity: 0;
                transform: scale(0.95) translateY(-10px);
            }

            to {
                opacity: 1;
                transform: scale(1) translateY(0);
            }
        }

        .dropdown-item {
            border-radius: 12px !important;
            padding: 12px 18px !important;
            font-weight: 700 !important;
            font-size: 0.85rem !important;
            display: flex !important;
            align-items: center !important;
            gap: 15px !important;
            transition: all 0.2s ease !important;
            color: #555 !important;
            margin-bottom: 4px !important;
        }

        .dropdown-item i {
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f8f9fa;
            border-radius: 10px;
            font-size: 1rem;
            color: #666;
            transition: all 0.2s ease;
        }

        .dropdown-item:hover {
            background: #f8f9fa !important;
            color: var(--main) !important;
            transform: translateX(5px);
        }

        .dropdown-item:hover i {
            background: var(--main);
            color: #fff;
        }

        .dropdown-item.active {
            background: var(--main) !important;
            color: #fff !important;
        }

        .dropdown-item.active i {
            background: rgba(255, 255, 255, 0.2);
            color: #fff;
        }

        .dropdown-divider {
            margin: 10px 0 !important;
            opacity: 0.1 !important;
        }

        .glass-card {
            background: white;
            border-radius: 30px;
            border: 1px solid #eee;
            box-shadow: 0 15px 35px rgba(0, 0, 0, 0.05);
            position: relative;
        }

        .card-header-custom {
            background: var(--main);
            padding: 40px;
            color: <%=(brandColor=='#FFC107') ? '#000': '#fff' %>;
            text-align: center;
        }

        .form-section {
            padding: 40px;
        }

        .user-info-bar {
            background: #f1f2f6;
            border-radius: 15px;
            padding: 15px 25px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .form-label {
            font-weight: 700;
            font-size: 0.9rem;
            color: #444;
            margin-bottom: 10px;
        }

        .form-control {
            border-radius: 12px;
            border: 2px solid #eee;
            padding: 12px 15px;
            transition: all 0.3s;
        }

        .form-control:focus {
            border-color: var(--main);
            box-shadow: 0 0 0 4px <%=brandColor %>20;
        }

        .btn-submit {
            background: var(--main);
            color: <%=(brandColor=='#FFC107') ? '#000': '#fff' %>;
            border: none;
            padding: 15px;
            border-radius: 15px;
            font-weight: 800;
            width: 100%;
            font-size: 1.1rem;
            margin-top: 20px;
            transition: all 0.3s;
        }

        .btn-submit:hover {
            filter: brightness(90%);
            transform: translateY(-2px);
        }

        .btn-back {
            color: #636e72;
            text-decoration: none;
            font-weight: 600;
            display: inline-block;
            margin-bottom: 20px;
            transition: 0.3s;
        }

        .btn-back:hover {
            color: var(--main);
        }

        .input-group-text {
            border-radius: 12px 0 0 12px;
            background: #fafafa;
            border: 2px solid #eee;
            border-right: none;
        }

        .input-group .form-control {
            border-left: none;
        }
    </style>
</head>

<body>
    <div class="container main-container">
        <a href="/dashboard" class="btn-back">
            <i class="fas fa-arrow-left me-2"></i>Kembali ke Dashboard
        </a>

        <div class="glass-card">
            <div class="card-header-custom">
                <i class="fas fa-file-signature fa-3x mb-3 opacity-75"></i>
                <div class="dropdown">
                    <h3 class="fw-800 mb-1 d-flex align-items-center justify-content-center cursor-pointer"
                        id="deptDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;">
                        <%= (locals.currentDept && locals.currentDept !=='ALL' ) ? locals.currentDept : 'DAILY REPORT'
                            %>
                            <i class="fas fa-chevron-down ms-2 fs-6 opacity-50"></i>
                    </h3>
                    <ul class="dropdown-menu shadow-lg" aria-labelledby="deptDropdown">
                        <li><a class="dropdown-item <%= (locals.currentDept === 'SALES MARKETING') ? 'active' : '' %>"
                                href="/marketing">
                                <i class="fas fa-bullhorn"></i> SALES MARKETING</a></li>
                        <li><a class="dropdown-item <%= (locals.currentDept === 'HR') ? 'active' : '' %>" href="/hr">
                                <i class="fas fa-users-cog"></i> HR</a></li>
                        <li><a class="dropdown-item <%= (locals.currentDept === 'FINANCE') ? 'active' : '' %>"
                                href="/finance">
                                <i class="fas fa-wallet"></i> FINANCE</a></li>
                        <li><a class="dropdown-item <%= (locals.currentDept === 'PURCHASING') ? 'active' : '' %>"
                                href="/purchasing">
                                <i class="fas fa-shopping-cart"></i> PURCHASING</a></li>
                        <li><a class="dropdown-item <%= (locals.currentDept === 'PRODUKSI') ? 'active' : '' %>"
                                href="/produksi">
                                <i class="fas fa-industry"></i> PRODUKSI</a></li>
                        <li>
                            <hr class="dropdown-divider">
                        </li>
                        <li><a class="dropdown-item <%= (locals.currentDept === 'ALL' || !locals.currentDept) ? 'active' : '' %>"
                                href="/dashboard">
                                <i class="fas fa-th-large"></i> DAILY REPORT</a></li>
                    </ul>
                </div>
                <p class="m-0 opacity-75">
                    <%= companyName %>
                </p>
            </div>

            <div class="form-section">
                <div class="user-info-bar">
                    <div>
                        <small class="text-muted d-block">Nama Karyawan</small>
                        <span class="fw-bold">
                            <%= user.full_name %>
                        </span>
                    </div>
                    <div class="text-end">
                        <small class="text-muted d-block">Jabatan</small>
                        <span class="badge"
                            style="background: var(--main); color: <%= (brandColor == '#FFC107') ? '#000' : '#fff' %>;">
                            <%= user.position %>
                        </span>
                    </div>
                </div>

                <form action="/submit-report" method="POST" enctype="multipart/form-data">
                    <input type="hidden" name="department" value="<%= user.role_name %>">

                    <div class="mb-4">
                        <label class="form-label"><i class="fas fa-tasks me-2 text-primary"></i>Daily Report
                            Details</label>
                        <textarea class="form-control" name="task" rows="4"
                            placeholder="Apa saja yang Anda kerjakan hari ini?" required></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label"><i
                                    class="fas fa-exclamation-triangle me-2 text-danger"></i>Masalah</label>
                            <textarea class="form-control" name="issue" rows="3"
                                placeholder="Kendala yang dihadapi..."></textarea>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label"><i class="fas fa-lightbulb me-2 text-success"></i>Solusi</label>
                            <textarea class="form-control" name="solution" rows="3"
                                placeholder="Langkah perbaikan..."></textarea>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label"><i class="fas fa-poll-h me-2 text-info"></i>Hasil / Progress
                            (%)</label>
                        <input type="text" class="form-control" name="result"
                            placeholder="Contoh: Selesai 100% atau Menunggu Vendor">
                    </div>

                    <div class="mb-4">
                        <label class="form-label"><i class="fas fa-paperclip me-2 text-secondary"></i>Lampiran
                            File</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-cloud-upload-alt"></i></span>
                            <input type="file" class="form-control" name="attachments" multiple>
                        </div>
                        <small class="text-muted mt-2 d-block">Bisa pilih lebih dari 1 file (Gambar/Dokumen)</small>
                    </div>

                    <button type="submit" class="btn-submit shadow">
                        <i class="fas fa-paper-plane me-2"></i>Kirim Laporan Sekarang
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script>
        // Intercept Form Submission untuk SweetAlert2
        document.querySelector('form').addEventListener('submit', function (e) {
            e.preventDefault();
            const form = this;
            const formData = new FormData(form);

            // Tampilkan Loading
            Swal.fire({
                title: 'Sedang Mengirim...',
                text: 'Mohon tunggu sebentar, laporan sedang diproses.',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            fetch(form.action, {
                method: 'POST',
                body: formData
            })
                .then(response => {
                    if (response.ok) {
                        Swal.fire({
                            icon: 'success',
                            title: 'Berhasil!',
                            text: 'Laporan kerja harian Anda telah terkirim.',
                            confirmButtonText: 'Kembali ke Dashboard',
                            confirmButtonColor: '#007AFF',
                            allowOutsideClick: false
                        }).then((result) => {
                            if (result.isConfirmed) {
                                window.location.href = '/dashboard';
                            }
                        });
                    } else {
                        throw new Error('Gagal mengirim data');
                    }
                })
                .catch(error => {
                    console.error(error);
                    Swal.fire({
                        icon: 'error',
                        title: 'Gagal',
                        text: 'Terjadi kesalahan saat mengirim laporan. Silakan coba lagi.',
                        confirmButtonColor: '#d33'
                    });
                });
        });
    </script>

    <script>
        // Animasi Smooth Transisi
        document.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', function (e) {
                if (this.hostname === window.location.hostname &&
                    !this.getAttribute('onclick') &&
                    !this.href.includes('logout')) {

                    e.preventDefault();
                    const target = this.href;
                    document.body.classList.add('fade-out');
                    setTimeout(() => { window.location.href = target; }, 400);
                }
            });
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>