<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof isDirector !=='undefined' && isDirector ? 'Director Login' : 'Login' %> — Daily Report <%= typeof
                isDirector !=='undefined' && isDirector ? 'Director System' : 'System' %>
    </title>
    <link rel="icon" type="image/png" href="/images/favicon.png">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

        *,
        *::before,
        *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            min-height: 100vh;
            background: linear-gradient(135deg, #f0f4ff 0%, #e0e7ff 50%, #dbeafe 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            perspective: 2000px;
        }

        .login-card-container {
            width: 100%;
            max-width: 900px;
            height: 560px;
            perspective: 2000px;
            margin: 0 auto;
            position: relative;
        }

        .login-card {
            width: 100%;
            height: 100%;
            position: relative;
            animation: cardEntrance 0.8s ease-out forwards;
        }

        .card-face {
            width: 100%;
            height: 100%;
            display: flex;
            background: white;
            border-radius: 28px;
            box-shadow: 0 30px 80px rgba(0, 0, 0, 0.3);
            overflow: hidden;
        }

        @keyframes cardEntrance {
            0% {
                opacity: 0;
                transform: scale(0.8) translateY(40px) rotateX(-10deg);
            }

            100% {
                opacity: 1;
                transform: scale(1) translateY(0) rotateX(0);
            }
        }

        .mode-switcher-outer {
            margin-bottom: 25px;
            text-align: center;
            animation: slideDown 0.5s ease-out 0.3s both;
            width: 100%;
        }

        @keyframes slideDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .btn-mode-toggle {
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(99, 102, 241, 0.2);
            color: #1e1b4b;
            padding: 10px 24px;
            border-radius: 50px;
            font-weight: 700;
            font-size: 0.9rem;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            transition: all 0.3s;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
        }

        .btn-mode-toggle:hover {
            background: #ffffff;
            color: #6366f1;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(99, 102, 241, 0.15);
            border-color: #6366f1;
        }

        .btn-mode-toggle.director {
            border-color: #f59e0b;
            color: #f59e0b;
            background: rgba(251, 191, 36, 0.1);
        }

        .login-banner {
            flex: 1;
            background: linear-gradient(145deg, #6366f1, #8b5cf6, #a855f7);
            padding: 60px 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            color: white;
            position: relative;
            overflow: hidden;
        }

        .login-banner.director-banner {
            background: linear-gradient(145deg, #1e293b, #334155, #0f172a);
            border-right: 3px solid #f59e0b;
        }

        .banner-badge {
            display: inline-block;
            background: rgba(255, 255, 255, 0.15);
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 0.75rem;
            text-transform: uppercase;
            margin-bottom: 20px;
            width: fit-content;
        }

        .banner-title {
            font-size: 2.22rem;
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 15px;
        }

        .banner-desc {
            font-size: 0.9rem;
            opacity: 0.8;
            line-height: 1.6;
        }

        .text-warning-custom {
            color: #f59e0b !important;
        }

        .banner-features {
            margin-top: 30px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .banner-feature-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.85rem;
        }

        .feature-icon {
            width: 28px;
            height: 28px;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-logo {
            width: 64px;
            height: 64px;
            margin-bottom: 25px;
            filter: drop-shadow(0 10px 15px rgba(0, 0, 0, 0.2));
            animation: float 3s ease-in-out infinite;
        }

        @keyframes float {
            0% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-10px);
            }

            100% {
                transform: translateY(0px);
            }
        }

        .login-form-area {
            flex: 1;
            padding: 60px 45px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            background: white;
        }

        .login-form-area h3 {
            font-size: 1.7rem;
            font-weight: 800;
            color: #1e1b4b;
            margin-bottom: 6px;
        }

        .subtitle {
            color: #6b7280;
            font-size: 0.92rem;
            margin-bottom: 30px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            color: #374151;
            margin-bottom: 8px;
        }

        .input-wrapper {
            position: relative;
        }

        .form-control {
            width: 100%;
            padding: 14px 18px 14px 44px;
            border: 1.5px solid #e2e8f0;
            border-radius: 12px;
            background: #f8fafc;
            transition: all 0.3s;
            font-size: 0.95rem;
        }

        .form-control:focus {
            border-color: #6366f1;
            background: white;
            outline: none;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        }

        .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            z-index: 5;
            transition: all 0.3s;
        }

        .form-control:focus+.input-icon {
            color: #6366f1;
            transform: translateY(-50%) scale(1.1);
        }

        .toggle-pw {
            position: absolute;
            right: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            cursor: pointer;
            z-index: 5;
            padding: 4px;
        }

        .btn-login {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1.05rem;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
        }

        .footer-text {
            text-align: center;
            margin-top: 24px;
            font-size: 0.82rem;
            color: #94a3b8;
        }

        @media (max-width: 992px) {
            .login-card-container {
                max-width: 720px;
            }
        }

        @media (max-width: 768px) {
            .login-card-container {
                max-width: 450px;
                height: auto;
                min-height: 500px;
                width: 95%;
            }

            .login-banner {
                display: none !important;
            }

            .login-form-area {
                padding: 40px 30px;
                width: 100% !important;
                flex: none !important;
            }

            .card-face {
                position: relative;
                height: auto;
                min-height: 500px;
                display: block;
            }

            /* Change to relative for auto height */
            .face-back {
                position: absolute;
            }

            /* Back side still needs absolute for flip */
        }
    </style>
</head>

<body>
    <div class="d-flex flex-column align-items-center w-100">
        <!-- Mode Switcher OUTSIDE the card -->
        <div class="mode-switcher-outer">
            <a href="<%= typeof isDirector !== 'undefined' && isDirector ? '/login' : '/director/login' %>"
                class="btn-mode-toggle <%= typeof isDirector !== 'undefined' && isDirector ? 'director' : '' %>"
                onclick="handleModeSwitch(event, this.href)">
                <i
                    class="fas <%= typeof isDirector !== 'undefined' && isDirector ? 'fa-user-shield' : 'fa-user-tie' %>"></i>
                <span>Switch to <%= typeof isDirector !=='undefined' && isDirector ? 'Standard Mode' : 'Director Mode'
                        %></span>
            </a>
        </div>

        <div class="login-card-container">
            <div class="login-card" id="loginCard">
                <!-- ════════ FACE FRONT (Current Mode) ════════ -->
                <div class="card-face face-front">
                    <div
                        class="login-banner <%= typeof isDirector !== 'undefined' && isDirector ? 'director-banner' : '' %>">
                        <img src="/images/favicon.png" alt="Logo" class="login-logo">
                        <span class="banner-badge">✦ v2.0 Multi-Level</span>
                        <h2 class="banner-title text-uppercase">
                            Daily Report<br>
                            <span
                                class="<%= typeof isDirector !== 'undefined' && isDirector ? 'text-warning-custom' : '' %>">
                                <%= typeof isDirector !=='undefined' && isDirector ? 'Director System' : 'System' %>
                            </span>
                        </h2>
                        <p class="banner-desc">Sistem pelaporan harian terintegrasi — <%= typeof isDirector
                                !=='undefined' && isDirector ? 'Eksklusif Jajaran Direksi'
                                : 'multi perusahaan, multi divisi, multi level akses' %>.</p>
                        <div class="banner-features">
                            <div class="banner-feature-item">
                                <div class="feature-icon"><i
                                        class="fas <%= typeof isDirector !== 'undefined' && isDirector ? 'fa-crown' : 'fa-building' %>"></i>
                                </div>
                                <span>
                                    <%= typeof isDirector !=='undefined' && isDirector ? 'Executive Oversight'
                                        : 'Multi PT & Divisi' %>
                                </span>
                            </div>
                            <div class="banner-feature-item">
                                <div class="feature-icon"><i class="fas fa-chart-bar"></i></div>
                                <span>Dashboard Visualisasi</span>
                            </div>
                            <div class="banner-feature-item">
                                <div class="feature-icon"><i class="fas fa-bell"></i></div>
                                <span>Notifikasi Real-time</span>
                            </div>
                        </div>
                    </div>

                    <div class="login-form-area">
                        <div class="mb-4">
                            <h3>
                                <%= typeof isDirector !=='undefined' && isDirector ? 'Director Login 🏛️'
                                    : 'Selamat Datang 👋' %>
                            </h3>
                            <p class="subtitle mb-0">
                                <%= typeof isDirector !=='undefined' && isDirector ? 'Portal Eksklusif Jajaran Direksi'
                                    : 'Masuk ke akun Anda untuk melanjutkan' %>
                            </p>
                        </div>

                        <form
                            action="<%= typeof isDirector !== 'undefined' && isDirector ? '/director/login' : '/login' %>"
                            method="POST" id="loginForm">
                            <div class="form-group">
                                <label class="form-label" for="emailInput">Alamat Email</label>
                                <div class="input-wrapper">
                                    <input type="email" class="form-control" id="emailInput" name="email"
                                        placeholder="email anda...." required>
                                    <i class="fas fa-envelope input-icon"></i>
                                </div>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="passwordInput">Password</label>
                                <div class="input-wrapper">
                                    <input type="password" class="form-control" id="passwordInput" name="password"
                                        placeholder="password anda...." required>
                                    <i class="fas fa-lock input-icon"></i>
                                    <i class="fas fa-eye-slash toggle-pw" id="togglePw"></i>
                                </div>
                            </div>
                            <button type="submit" class="btn-login" id="loginBtn">
                                <i class="fas fa-sign-in-alt me-2"></i> Masuk Sekarang
                            </button>
                        </form>
                    </div>
                </div>

                <!-- face-back removed, using direct redirect instead -->
            </div>
        </div>

        <script>
            // Mode Switch — langsung redirect tanpa animasi flip
            function handleModeSwitch(e, href) {
                e.preventDefault();
                window.location.href = href;
            }

            // Toggle Password Visibility (Front Face)
            const togglePw = document.getElementById('togglePw');
            const pwInput = document.getElementById('passwordInput');
            if (togglePw && pwInput) {
                togglePw.addEventListener('click', () => {
                    const isText = pwInput.type === 'text';
                    pwInput.type = isText ? 'password' : 'text';
                    togglePw.className = isText ? 'fas fa-eye-slash toggle-pw' : 'fas fa-eye toggle-pw';
                });
            }

            // Remember me & Input States
            const inputs = document.querySelectorAll('.form-control');
            const emailInput = document.getElementById('emailInput');

            const updateInputState = (input) => {
                if (input.value.trim() !== "") {
                    input.classList.add('is-filled');
                } else {
                    input.classList.remove('is-filled');
                }
            };

            inputs.forEach(input => {
                setTimeout(() => updateInputState(input), 120);
                input.addEventListener('input', () => updateInputState(input));
                input.addEventListener('change', () => updateInputState(input));
            });

            const savedEmail = localStorage.getItem('dr_email');
            if (savedEmail && emailInput) {
                emailInput.value = savedEmail;
                updateInputState(emailInput);
            }

            // Login Form Submission UI
            const loginForm = document.getElementById('loginForm');
            if (loginForm) {
                loginForm.addEventListener('submit', function (e) {
                    const btn = document.getElementById('loginBtn');
                    if (btn) {
                        btn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Authenticating...';
                        btn.style.opacity = '0.7';
                    }
                    if (emailInput) {
                        localStorage.setItem('dr_email', emailInput.value);
                    }
                });
            }

        // Handle Errors with SweetAlert
        <% if (typeof error !== 'undefined' && error) { %>
                Swal.fire({
                    icon: 'error',
                    title: 'Login Gagal',
                    text: '<%= error %>',
                    confirmButtonColor: '#6366f1'
                });
        <% } %>
        </script>
</body>

</html>